// This is your Prisma schema file for the Chenchugudi Festival Platform
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Gallery photos/videos uploaded by admin
model GalleryImage {
  id          Int      @id @default(autoincrement())
  title       String
  titleTe     String?  // Telugu title
  imageUrl    String   // stores Cloudinary URL (image or video thumbnail)
  mediaType   String   @default("IMAGE") // IMAGE, VIDEO, YOUTUBE
  videoUrl    String?  // Original video URL or YouTube URL
  publicId    String?  // Cloudinary asset ID for deletion
  uploadedBy  String
  eventDate   DateTime @default(now())
  eventName   String?
  eventNameTe String?  // Telugu event name
  createdAt   DateTime @default(now())
}

// Festival announcements/news
model Announcement {
  id        Int      @id @default(autoincrement())
  title     String
  titleTe   String?  // Telugu title
  body      String
  bodyTe    String?  // Telugu body
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

// Push subscriptions for live notifications
model PushSubscription {
  id        Int      @id @default(autoincrement())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

// Track unique page views on a daily basis by IP
model UserVisit {
  id        Int      @id @default(autoincrement())
  ipAddress String
  visitDate String   // Format: YYYY-MM-DD for simple day-by-day grouping
  createdAt DateTime @default(now())

  @@unique([ipAddress, visitDate])
}

// Track user website feedback (likes/dislikes)
model Feedback {
  id        Int      @id @default(autoincrement())
  isLike    Boolean  // true for Like, false for Dislike
  ipAddress String   @unique // Only one feedback entry allowed per unique IP
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Global site settings (e.g., Live Stream configuration)
model SiteSetting {
  id                 Int      @id @default(1)
  liveStreamUrl      String?  // YouTube video ID or URL
  liveStreamPlatform String   @default("youtube") // youtube, facebook, twitch, instagram
  isLiveActive       Boolean  @default(false)
  updatedAt          DateTime @updatedAt
}

// Festival Year Configuration
model FestivalYear {
  id          Int      @id @default(autoincrement())
  year        String   @unique // e.g. "2026"
  pamphletUrl String?  // URL or path to the pamphlet PDF
  isActive    Boolean  @default(false)
  events      EventSchedule[]
  sponsors    DailySponsor[]
  createdAt   DateTime @default(now())
}

// Main Event Schedule
model EventSchedule {
  id          Int      @id @default(autoincrement())
  yearId      Int
  year        FestivalYear @relation(fields: [yearId], references: [id])
  date        String
  dayTe       String
  dayEn       String
  eventTe     String
  eventEn     String
  sponsorTe   String?
  sponsorEn   String?
  icon        String?
  highlight   Boolean  @default(false)
  fee         String?
  createdAt   DateTime @default(now())
}

// Daily Pooja Sponsors
model DailySponsor {
  id          Int      @id @default(autoincrement())
  yearId      Int
  year        FestivalYear @relation(fields: [yearId], references: [id])
  date        String
  dayTe       String
  dayEn       String
  nameTe      String
  nameEn      String
  locationTe  String?
  locationEn  String?
  createdAt   DateTime @default(now())
}
